# =====================================================================
# .gitignore — Samambaia Spa
# =====================================================================

# ── Dependencias Node.js ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Variables de Entorno (¡NUNCA subir a Git!) ────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Base de Datos SQLite local ────────────────────────────────────────
# El archivo .db/.sqlite local NO se sube; en producción se crea automáticamente.
*.sqlite
*.db

# ── Archivos de Sistema Operativo ─────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────
logs/
*.log

# ── Editores / IDEs ───────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Builds / Cache ────────────────────────────────────────────────────
.cache/
dist/
