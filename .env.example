# =====================================================================
# .env.example — Plantilla de Variables de Entorno
# =====================================================================
# Proyecto Productivo SENA — Samambaia Spa (Modelo SaaS Multi-Empresa)
#
# INSTRUCCIONES:
# 1. Copie este archivo y renómbrelo a ".env"
# 2. Rellene los valores para su entorno local o configúrelos en el
#    panel de variables de entorno de Render / Railway en producción.
# 3. NUNCA suba el archivo ".env" a Git (ya está en .gitignore).
# =====================================================================

# ── Servidor ─────────────────────────────────────────────────────────
# Puerto en el que escucha Express. Render/Railway lo inyectan automáticamente.
PORT=3000

# ── Seguridad ─────────────────────────────────────────────────────────
# Secreto para firmar tokens de administración (SHA-256 + slug).
# Reemplace por una cadena larga y aleatoria en producción.
# Ejemplo: openssl rand -base64 48
JWT_SECRET=super_secret_token_key_sena_2026_change_me_in_prod

# ── Base de Datos SQLite ───────────────────────────────────────────────
# Ruta del archivo SQLite. En Render/Railway use un volumen persistente
# o deje el valor por defecto (relativo al directorio del proyecto).
# DB_PATH=./database.sqlite

# ── Entorno de ejecución ──────────────────────────────────────────────
NODE_ENV=production

# ── Logging ───────────────────────────────────────────────────────────
DEBUG=false

# ── Integración Google Calendar (Opcional) ────────────────────────────
# Si no usa Google Calendar, deje estas variables vacías o coméntelas.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=mi-cuenta@proyecto.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GOOGLE_CALENDAR_ID=primary
